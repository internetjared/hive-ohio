---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
import Section from '../components/Section.astro';
import ServiceCard from '../components/ServiceCard.astro';
import BeforeAfter from '../components/BeforeAfter.astro';
import TestimonialCard from '../components/TestimonialCard.astro';
import CTASection from '../components/CTASection.astro';
import ContactForm from '../components/ContactForm.astro';
---

<BaseLayout
  title="HIVE — Home Improvement + Value Estimates in Ohio"
  description="Real estate, renovations, and homeowner guidance in Central Ohio. Free consultations."
  currentPage="/"
>

  {/* ==========================================
      Section 1: Hero
      ========================================== */}
  <Hero
    images={[
      "/images/photos/hero/patio-path.jpg",
      "/images/photos/favorites/2010mh-living-fireplace.jpg",
      "/images/photos/hero/kitchen-sink.jpg",
      "/images/photos/hero/backyard-south.jpg",
      "/images/photos/hero/exterior-front.jpg",
    ]}
    headline="Your home. Your plan.<br>Built right."
    subheadline="Thoughtful design meets craftsmanship — real estate, renovations, and homeowner guidance in Central Ohio."
    ctaText="Let's Talk About Your Home"
    ctaLink="#contact"
    secondaryCtaText="See Our Work"
    secondaryCtaLink="#featured-projects"
  />

  {/* ==========================================
      Section 2: Three Service Pillars
      ========================================== */}
  <Section id="services">
    <div class="services-intro" data-reveal="up">
      <h2>How We Help</h2>
      <p>Three ways HIVE brings engineering judgment, construction knowledge, and real estate guidance together for you.</p>
    </div>
    <div class="services-grid">
      <div data-reveal="up" data-reveal-delay="1">
        <ServiceCard
          title="Real Estate"
          description="Not just buying and selling — understanding what you're getting, what it will cost, and how it fits your plan. Engineering judgment meets real estate guidance."
          href="#contact"
        >
          <img slot="icon" src="/images/icons/icon-home.png" alt="" width="56" height="56" class="service-icon-img" />
        </ServiceCard>
      </div>

      <div data-reveal="up" data-reveal-delay="2">
        <ServiceCard
          title="Renovations"
          description="Hands-on construction from kitchens to whole-house transformations. PE-backed planning meets craftsmanship. Functional, not just cosmetic."
          href="#contact"
        >
          <img slot="icon" src="/images/icons/icon-hammer.png" alt="" width="56" height="56" class="service-icon-img" />
        </ServiceCard>
      </div>

      <div data-reveal="up" data-reveal-delay="3">
        <ServiceCard
          title="DIY Coaching"
          description="Guidance and support for homeowners who want to be involved and empowered. Let's turn your goals into a plan and figure out how to work together."
          href="#contact"
        >
          <img slot="icon" src="/images/icons/icon-lightbulb.png" alt="" width="56" height="56" class="service-icon-img" />
        </ServiceCard>
      </div>
    </div>
  </Section>

  {/* ==========================================
      Section 3: Featured Projects (Before/After)
      ========================================== */}
  <Section id="featured-projects" background="earth" padding="default">
    <div class="projects-intro" data-reveal="up">
      <h2>See the Transformation</h2>
      <p>Real projects. Real results. Every renovation starts with a plan and ends with a home you love.</p>
    </div>
    <div class="projects-grid">
      <BeforeAfter
        projectName="Kitchen Renovation"
        description="Complete kitchen transformation with structural upgrades"
        beforeImage="/images/photos/214-np/kitchen-before.jpg"
        afterImage="/images/photos/214-np/kitchen-after.jpg"

      />
      <BeforeAfter
        projectName="Bathroom Remodel"
        description="Updated vanity and finishes for a clean, modern look"
        beforeImage="/images/photos/214-np/bathroom-before.jpg"
        afterImage="/images/photos/214-np/bathroom-after.jpg"

      />
      <BeforeAfter
        projectName="Exterior Refresh"
        description="Full curb appeal overhaul from foundation to roof"
        beforeImage="/images/photos/2010-mh/exterior-before.jpg"
        afterImage="/images/photos/2010-mh/exterior-after.jpg"

      />
      <BeforeAfter
        projectName="Patio & Stone Path"
        description="Custom stone patio and walkway from bare yard to outdoor living space"
        beforeImage="/images/photos/patio-before.png"
        afterImage="/images/photos/patio-after.jpg"

      />
    </div>
  </Section>

  {/* ==========================================
      Section 4: Credibility / About Teaser
      ========================================== */}
  <Section id="about-teaser">
    <div class="about-grid">
      <div class="about-image" data-reveal="left">
        <img src="/images/logo/hive-lockup-earth.png" alt="HIVE — Home Improvements + Value Estimates" width="360" height="360" class="about-logo-placeholder" />
      </div>
      <div class="about-content" data-reveal="right">
        <h2>Built Different</h2>
        <p class="about-lead">
          John is a licensed Professional Engineer and Realtor in Ohio. He combines 20 years of engineering experience with hands-on construction knowledge to help clients make smarter decisions about their homes.
        </p>
        <p>
          Most agents help people transact. HIVE helps people plan. Whether you're buying your first home, renovating the one you're in, or figuring out what a property could become — HIVE brings the engineering judgment, construction experience, and real estate guidance to get it right.
        </p>
        <ul class="credentials-list">
          <li>
            <svg width="18" height="18" viewBox="0 0 18 18" fill="none" aria-hidden="true"><path d="M4 9L7.5 12.5L14 5.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
            Licensed Professional Engineer (PE) — Ohio
          </li>
          <li>
            <svg width="18" height="18" viewBox="0 0 18 18" fill="none" aria-hidden="true"><path d="M4 9L7.5 12.5L14 5.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
            Licensed Realtor — Ohio
          </li>
          <li>
            <svg width="18" height="18" viewBox="0 0 18 18" fill="none" aria-hidden="true"><path d="M4 9L7.5 12.5L14 5.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
            M.S. Civil Engineering — Construction Management
          </li>
        </ul>
        <a href="#contact" class="btn btn-outline">Work With Us</a>
      </div>
    </div>
  </Section>

  {/* ==========================================
      Section 5: Testimonials
      ========================================== */}
  <Section id="testimonials" background="ancient-page">
    <div class="testimonials-intro" data-reveal="up">
      <h2>What Clients Say</h2>
    </div>
    <div class="testimonials-layout">
      <div class="testimonial-featured" data-reveal="up">
        <TestimonialCard
          quote="I and members of my family had occupied the home since 1960. It was very dear to me and I shared my love and attachment of my childhood home with John. He immediately embraced my memories and took great care to keep me abreast of the upgrades and renovations while still maintaining the character of the property. John's creativity and expertise in the area of remodeling far surpasses anything that would be considered to be normal or just average. He would be an asset to any project."
          name="Linda"
          context="Eastgate — Home renovation"
          featured={true}
        />
      </div>
      <div class="testimonials-pair">
        <div data-reveal="up" data-reveal-delay="1">
          <TestimonialCard
            quote="John was an invaluable asset in helping us evaluate options and showing us exactly how we could keep our house in Columbus as a viable rental. He explained the costs and reasons for each part of work that could be done to prepare the house for renters and how it could help avoid issues and unnecessary maintenance costs once they moved in. The work was done exactly as he described it and our renters have been very happy in the space now for 3 years."
            name="David & Jamie"
            context="Franklin Park — Rental conversion"
          />
        </div>
        <div data-reveal="up" data-reveal-delay="2">
          <TestimonialCard
            quote="After months of research and shopping prices, we hired HIVE to tear down the old deck and build a new one. They did a fantastic job. It was a pleasure to have John over at the house, chat about all of our options, and answer all of our questions. We were very happy with the process and the finished product. We highly recommend HIVE!"
            name="Jeff & Beth"
            context="Worthington — Deck build"
          />
        </div>
      </div>
    </div>
  </Section>

  {/* ==========================================
      Section 7: Contact Form
      ========================================== */}
  <Section id="contact" padding="wide">
    <div data-reveal="up">
      <div class="contact-options">
        <a href="mailto:hello@HIVEohio.com" class="contact-email-option">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="2" y="4" width="20" height="16" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/></svg>
          hello@HIVEohio.com
        </a>
      </div>
      <ContactForm
        heading="Let's Talk About Your Home"
        subtext="Free consultations. No pressure. Tell us a little about what you're looking for."
        formAccessKey="1baa0fbd-6104-45c1-986e-cf757773be07"
      />
    </div>
  </Section>

  {/* ==========================================
      Section 8: Final CTA
      ========================================== */}
  <CTASection
    headline="Ready to start planning?"
    subtext="Free estimates. Free consultations. Just a conversation about what's possible."
    buttonText="Schedule a Free Consultation"
    buttonLink="#contact"
    secondaryText="Or email us at hello@HIVEohio.com"
    secondaryLink="mailto:hello@HIVEohio.com"
    backgroundType="image"
    backgroundValue="/images/photos/favorites/46wt-backyard-south.jpg"
  />

</BaseLayout>

<style>
  /* Section 2: Services */
  .services-intro {
    text-align: center;
    margin-bottom: 3rem;
  }

  .services-intro p {
    margin-inline: auto;
    margin-top: 0.75rem;
    font-size: 1.05rem;
    opacity: 0.75;
  }

  .services-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5rem;
  }

  .services-grid > div {
    display: flex;
  }

  .services-grid > div > :global(.service-card) {
    flex: 1;
  }

  :global(.service-icon-img) {
    width: 56px;
    height: 56px;
    object-fit: contain;
  }

  @media (max-width: 768px) {
    .services-grid {
      grid-template-columns: 1fr;
      gap: 1.25rem;
    }
  }

  /* Section 3: Projects */
  .projects-intro {
    text-align: center;
    margin-bottom: 3rem;
  }

  .projects-intro p {
    margin-inline: auto;
    margin-top: 0.75rem;
    font-size: 1.05rem;
    opacity: 0.75;
  }

  #featured-projects :global(.container) {
    max-width: 1800px;
  }

  .projects-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 2.5rem 2rem;
  }

  .projects-grid > :global(.before-after) {
    padding: 0.75rem;
    background: rgba(255, 255, 255, 0.05);
    border-radius: 12px;
  }

  @media (max-width: 768px) {
    .projects-grid {
      grid-template-columns: 1fr;
      gap: 2.5rem;
    }
  }

  /* Section 4: About */
  .about-grid {
    display: grid;
    grid-template-columns: 1fr 1.5fr;
    gap: 4rem;
    align-items: center;
  }

  .about-image {
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .about-logo-placeholder {
    width: 320px;
    height: auto;
    object-fit: contain;
    opacity: 0.85;
  }

  .about-content h2 {
    margin-bottom: 1.25rem;
  }

  .about-lead {
    font-size: 1.1rem;
    line-height: 1.65;
    margin-bottom: 1rem;
  }

  .about-content > p {
    line-height: 1.65;
    opacity: 0.8;
    margin-bottom: 1.5rem;
  }

  .credentials-list {
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
    margin-bottom: 2rem;
  }

  .credentials-list li {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    font-size: 0.9rem;
    font-weight: 400;
  }

  .credentials-list svg {
    color: var(--color-olive);
    flex-shrink: 0;
  }

  @media (max-width: 768px) {
    .about-grid {
      grid-template-columns: 1fr;
      gap: 2rem;
      text-align: center;
    }

    .about-image {
      order: -1;
    }

    .about-logo-placeholder {
      width: 220px;
      height: auto;
    }

    .credentials-list {
      align-items: center;
    }

    .about-content > .btn {
      margin-inline: auto;
    }
  }

  /* Section 6: Testimonials */
  .testimonials-intro {
    text-align: center;
    margin-bottom: 3rem;
  }

  .testimonials-layout {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  .testimonial-featured {
    max-width: 900px;
    margin-inline: auto;
    width: 100%;
  }

  .testimonials-pair {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1.5rem;
  }

  .testimonials-pair > div {
    display: flex;
  }

  .testimonials-pair > div > :global(.testimonial-card) {
    flex: 1;
  }

  @media (max-width: 768px) {
    .testimonials-pair {
      grid-template-columns: 1fr;
      gap: 1.25rem;
    }
  }

  /* Contact email option */
  .contact-options {
    text-align: center;
    margin-bottom: 1.5rem;
  }

  .contact-email-option {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 1.05rem;
    font-weight: 700;
    color: var(--color-honey);
    transition: opacity var(--transition-fast);
  }

  .contact-email-option:hover {
    opacity: 0.8;
  }
</style>
