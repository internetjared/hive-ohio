---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
import Section from '../components/Section.astro';
import ServiceCard from '../components/ServiceCard.astro';
import BeforeAfter from '../components/BeforeAfter.astro';
import TestimonialCard from '../components/TestimonialCard.astro';
import CTASection from '../components/CTASection.astro';
---

<BaseLayout
  title="HIVE — Ohio Home Improvement & Value Estimates"
  description="Engineering-backed real estate, renovations, and homeowner guidance in Central Ohio. Free consultations."
  currentPage="/"
>

  {/* ==========================================
      Section 1: Hero
      ========================================== */}
  <Hero
    images={[
      "/images/photos/hero/patio-path.jpg",
      "/images/photos/favorites/2010mh-living-fireplace.jpg",
      "/images/photos/hero/kitchen-sink.jpg",
      "/images/photos/hero/backyard-south.jpg",
      "/images/photos/hero/exterior-front.jpg",
    ]}
    headline="Your home. Your plan.<br>Built right."
    subheadline="Engineering-backed real estate, renovations, and homeowner guidance in Central Ohio."
    ctaText="Let's Talk About Your Home"
    ctaLink="/contact"
    secondaryCtaText="See Our Work"
    secondaryCtaLink="/projects"
  />

  {/* ==========================================
      Section 2: Three Service Pillars
      ========================================== */}
  <Section id="services">
    <div class="services-intro">
      <h2>How We Help</h2>
      <p>Three ways HIVE brings engineering judgment, construction knowledge, and real estate guidance together for you.</p>
    </div>
    <div class="services-grid">
      <ServiceCard
        title="Real Estate"
        description="Not just buying and selling — understanding what you're getting, what it will cost, and how it fits your plan. Engineering judgment meets real estate guidance."
        href="/services/real-estate"
      >
        <svg slot="icon" width="48" height="48" viewBox="0 0 48 48" fill="none">
          {/* House with magnifying glass — inspection/evaluation */}
          <path d="M6 22L22 8L38 22" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
          <path d="M10 20v20h10v-12h4v12h14V20" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
          <path d="M18 28h4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
          <circle cx="37" cy="14" r="7" stroke="currentColor" stroke-width="1.5"/>
          <path d="M42 19l4 4" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
          <path d="M35 12l1 4M34 14h6" stroke="currentColor" stroke-width="1" stroke-linecap="round" opacity="0.5"/>
        </svg>
      </ServiceCard>

      <ServiceCard
        title="Renovations"
        description="Hands-on construction from kitchens to whole-house transformations. PE-backed planning meets craftsmanship. Structural, not just cosmetic."
        href="/services/renovations"
      >
        <svg slot="icon" width="48" height="48" viewBox="0 0 48 48" fill="none">
          {/* Hammer + carpenter square — construction meets precision */}
          <path d="M6 6v36h4V10h28" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
          <path d="M10 14h2M10 20h2M10 26h2M10 32h2M10 38h2" stroke="currentColor" stroke-width="1" stroke-linecap="round" opacity="0.5"/>
          <path d="M16 10h2M22 10h2M28 10h2M34 10h2" stroke="currentColor" stroke-width="1" stroke-linecap="round" opacity="0.5" transform="rotate(90 24 10)"/>
          <path d="M28 18l-8 8 2 2 8-8" stroke="currentColor" stroke-width="1.5" stroke-linejoin="round"/>
          <path d="M30 16l6-4 4 4-4 6" stroke="currentColor" stroke-width="1.5" stroke-linejoin="round"/>
          <path d="M22 28l-8 8" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
          <path d="M12 34l4 4M10 36l6 2M12 38l2-4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </ServiceCard>

      <ServiceCard
        title="DIY Coaching"
        description="Guidance for homeowners who want to be involved. One-on-one consults, video walkthroughs, workshop setup. Do it right, whether you hire us or do it yourself."
        href="/services/diy-coaching"
      >
        <svg slot="icon" width="48" height="48" viewBox="0 0 48 48" fill="none">
          {/* Lightbulb + wrench — knowledge meets hands-on skill */}
          <path d="M18 18a8 8 0 1 1 10.5 7.6c-.8.7-1.5 1.9-1.5 3.4v1h-6v-1c0-1.5-.7-2.7-1.5-3.4A8 8 0 0 1 18 18z" stroke="currentColor" stroke-width="1.5" stroke-linejoin="round"/>
          <path d="M21 30h6v3a2 2 0 0 1-2 2h-2a2 2 0 0 1-2-2v-3z" stroke="currentColor" stroke-width="1.5" stroke-linejoin="round"/>
          <path d="M24 4v4M38 18h-4M14 18h-4M34.5 8.5l-2.8 2.8M13.5 8.5l2.8 2.8" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" opacity="0.5"/>
          <path d="M6 38l4.5-4.5M4.5 39.5l2-2" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
          <circle cx="9" cy="41" r="2" stroke="currentColor" stroke-width="1.5"/>
          <path d="M11 39l4-4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
          <path d="M13 33l5 5M15 35l-4-1 1 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </ServiceCard>
    </div>
  </Section>

  {/* ==========================================
      Section 3: Featured Projects (Before/After)
      ========================================== */}
  <Section id="featured-projects" background="earth" padding="default">
    <div class="projects-intro">
      <h2>See the Transformation</h2>
      <p>Real projects. Real results. Every renovation starts with a plan and ends with a home you love.</p>
    </div>
    <div class="projects-grid">
      <BeforeAfter
        projectName="Kitchen Renovation"
        description="Complete kitchen transformation with structural upgrades"
        beforeImage="/images/photos/214-np/kitchen-before.jpg"
        afterImage="/images/photos/214-np/kitchen-after.jpg"
        href="/projects"
      />
      <BeforeAfter
        projectName="Bathroom Remodel"
        description="Updated vanity and finishes for a clean, modern look"
        beforeImage="/images/photos/214-np/bathroom-before.jpg"
        afterImage="/images/photos/214-np/bathroom-after.jpg"
        href="/projects"
      />
      <BeforeAfter
        projectName="Exterior Refresh"
        description="Full curb appeal overhaul from foundation to roof"
        beforeImage="/images/photos/2010-mh/exterior-before.jpg"
        afterImage="/images/photos/2010-mh/exterior-after.jpg"
        href="/projects"
      />
      <BeforeAfter
        projectName="Patio & Stone Path"
        description="Custom stone patio and walkway from bare yard to outdoor living space"
        beforeImage="/images/photos/patio-before.png"
        afterImage="/images/photos/patio-after.jpg"
        href="/projects"
      />
    </div>
    <div class="projects-cta">
      <a href="/projects" class="btn btn-secondary">View All Projects</a>
    </div>
  </Section>

  {/* ==========================================
      Section 4: Credibility / About Teaser
      ========================================== */}
  <Section id="about-teaser">
    <div class="about-grid">
      <div class="about-image">
        <img src="/images/logo/hive-logo-green.png" alt="HIVE logo" width="280" height="280" class="about-logo-placeholder" />
      </div>
      <div class="about-content">
        <h2>Built Different</h2>
        <p class="about-lead">
          John is a licensed Professional Engineer and Realtor in Ohio. He combines 20 years of engineering experience with hands-on construction knowledge to help clients make smarter decisions about their homes.
        </p>
        <p>
          Most agents help people transact. HIVE helps people plan. Whether you're buying your first home, renovating the one you're in, or figuring out what a property could become — HIVE brings the engineering judgment, construction experience, and real estate guidance to get it right.
        </p>
        <ul class="credentials-list">
          <li>
            <svg width="18" height="18" viewBox="0 0 18 18" fill="none" aria-hidden="true"><path d="M4 9L7.5 12.5L14 5.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
            Licensed Professional Engineer (PE) — Ohio
          </li>
          <li>
            <svg width="18" height="18" viewBox="0 0 18 18" fill="none" aria-hidden="true"><path d="M4 9L7.5 12.5L14 5.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
            Licensed Realtor — Ohio
          </li>
          <li>
            <svg width="18" height="18" viewBox="0 0 18 18" fill="none" aria-hidden="true"><path d="M4 9L7.5 12.5L14 5.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
            Project Management Professional (PMP) — In Progress
          </li>
        </ul>
        <a href="/about" class="btn btn-outline">Our Story</a>
      </div>
    </div>
  </Section>

  {/* ==========================================
      Section 5: Testimonials
      ========================================== */}
  <Section id="testimonials" background="ancient-page">
    <div class="testimonials-intro">
      <h2>What Clients Say</h2>
    </div>
    <div class="testimonials-grid">
      <TestimonialCard
        quote="John didn't just help us find a house — he helped us understand what we were actually buying. The inspection walkthrough alone saved us thousands in unexpected repairs."
        name="Sarah M."
        context="Home buyer"
      />
      <TestimonialCard
        quote="We came in with a vision and a tight budget. John helped us figure out what was worth doing, what could wait, and what would actually add value. The kitchen turned out better than we imagined."
        name="David & Rachel T."
        context="Renovation clients"
      />
      <TestimonialCard
        quote="I wanted to do the work myself but didn't know where to start. A two-hour session with John replaced weeks of YouTube research. He showed me the right approach and the right tools."
        name="Marcus L."
        context="DIY coaching client"
      />
    </div>
  </Section>

  {/* ==========================================
      Section 6: Final CTA
      ========================================== */}
  <CTASection
    headline="Ready to talk about your home?"
    subtext="Free consultations. No pressure. Just a conversation about what's possible."
    buttonText="Schedule a Free Consultation"
    buttonLink="/contact"
    secondaryText="Or email us at hello@hive.com"
    secondaryLink="mailto:hello@hive.com"
    backgroundType="image"
    backgroundValue="/images/photos/favorites/46wt-backyard-south.jpg"
  />

</BaseLayout>

<style>
  /* Section 2: Services */
  .services-intro {
    text-align: center;
    margin-bottom: 3rem;
  }

  .services-intro p {
    margin-inline: auto;
    margin-top: 0.75rem;
    font-size: 1.05rem;
    opacity: 0.75;
  }

  .services-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5rem;
  }

  @media (max-width: 768px) {
    .services-grid {
      grid-template-columns: 1fr;
      gap: 1.25rem;
    }
  }

  /* Section 3: Projects */
  .projects-intro {
    text-align: center;
    margin-bottom: 3rem;
  }

  .projects-intro p {
    margin-inline: auto;
    margin-top: 0.75rem;
    font-size: 1.05rem;
    opacity: 0.75;
  }

  #featured-projects :global(.container) {
    max-width: 1400px;
    padding-inline: 1rem;
  }

  .projects-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 2.5rem 2rem;
  }

  .projects-grid > :global(.before-after) {
    display: grid;
    grid-template-rows: subgrid;
    grid-row: span 3;
    padding: 1.5rem;
    background: rgba(255, 255, 255, 0.05);
    border-radius: 12px;
  }

  @media (max-width: 768px) {
    .projects-grid {
      grid-template-columns: 1fr;
      gap: 2.5rem;
    }
  }

  .projects-cta {
    text-align: center;
    margin-top: 3rem;
  }

  /* Section 4: About */
  .about-grid {
    display: grid;
    grid-template-columns: 1fr 1.5fr;
    gap: 4rem;
    align-items: center;
  }

  .about-image {
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .about-logo-placeholder {
    width: 280px;
    height: 280px;
    object-fit: contain;
    opacity: 0.6;
  }

  .about-content h2 {
    margin-bottom: 1.25rem;
  }

  .about-lead {
    font-size: 1.1rem;
    line-height: 1.65;
    margin-bottom: 1rem;
  }

  .about-content > p {
    line-height: 1.65;
    opacity: 0.8;
    margin-bottom: 1.5rem;
  }

  .credentials-list {
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
    margin-bottom: 2rem;
  }

  .credentials-list li {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    font-size: 0.9rem;
    font-weight: 400;
  }

  .credentials-list svg {
    color: var(--color-olive);
    flex-shrink: 0;
  }

  @media (max-width: 768px) {
    .about-grid {
      grid-template-columns: 1fr;
      gap: 2rem;
      text-align: center;
    }

    .about-image {
      order: -1;
    }

    .about-logo-placeholder {
      width: 180px;
      height: 180px;
    }

    .credentials-list {
      align-items: center;
    }

    .about-content > .btn {
      margin-inline: auto;
    }
  }

  /* Section 5: Testimonials */
  .testimonials-intro {
    text-align: center;
    margin-bottom: 3rem;
  }

  .testimonials-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5rem;
  }

  @media (max-width: 768px) {
    .testimonials-grid {
      grid-template-columns: 1fr;
      gap: 1.25rem;
    }
  }
</style>
