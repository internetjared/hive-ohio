---
interface Props {
  images: string[];
  headline: string;
  subheadline?: string;
  ctaText?: string;
  ctaLink?: string;
  secondaryCtaText?: string;
  secondaryCtaLink?: string;
  interval?: number;
}

const {
  images,
  headline,
  subheadline,
  ctaText,
  ctaLink,
  secondaryCtaText,
  secondaryCtaLink,
  interval = 5000,
} = Astro.props;
---

<section class="hero" data-hero-slideshow data-interval={interval}>
  <div class="hero-bg">
    {images.map((src, i) => (
      <img
        src={src}
        alt=""
        loading={i === 0 ? 'eager' : 'lazy'}
        class={`hero-slide ${i === 0 ? 'is-active' : ''}`}
        data-slide-index={i}
      />
    ))}
    <div class="hero-overlay"></div>
  </div>

  <button class="hero-arrow hero-arrow--prev" data-hero-prev aria-label="Previous slide">
    <svg width="28" height="28" viewBox="0 0 24 24" fill="none" aria-hidden="true">
      <path d="M15 5L8 12L15 19" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
    </svg>
  </button>
  <button class="hero-arrow hero-arrow--next" data-hero-next aria-label="Next slide">
    <svg width="28" height="28" viewBox="0 0 24 24" fill="none" aria-hidden="true">
      <path d="M9 5L16 12L9 19" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
    </svg>
  </button>

  <div class="hero-content">
    <h1 class="hero-headline" set:html={headline} />
    {subheadline && <p class="hero-subheadline">{subheadline}</p>}
    <div class="hero-actions">
      {ctaText && ctaLink && (
        <a href={ctaLink} class="btn btn-primary">{ctaText}</a>
      )}
      {secondaryCtaText && secondaryCtaLink && (
        <a href={secondaryCtaLink} class="btn btn-secondary">{secondaryCtaText}</a>
      )}
    </div>
  </div>

  <div class="hero-scroll-indicator" aria-hidden="true">
    <svg width="20" height="32" viewBox="0 0 20 32" fill="none">
      <rect x="1" y="1" width="18" height="30" rx="9" stroke="currentColor" stroke-width="1.5"/>
      <circle class="hero-scroll-dot" cx="10" cy="8" r="2.5" fill="currentColor"/>
    </svg>
  </div>
</section>

<style>
  .hero {
    position: relative;
    min-height: 85vh;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
  }

  .hero-bg {
    position: absolute;
    inset: 0;
  }

  .hero-slide {
    position: absolute;
    top: -15%;
    left: -15%;
    width: 130%;
    height: 130%;
    max-width: none;
    object-fit: cover;
    opacity: 0;
    transition: opacity 1.2s ease-in-out;
    will-change: transform;
  }

  .hero-slide.is-active {
    opacity: 1;
  }

  .hero-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      135deg,
      rgba(60, 56, 47, 0.7) 0%,
      rgba(60, 56, 47, 0.45) 50%,
      rgba(60, 56, 47, 0.25) 100%
    );
  }

  /* === Arrows === */
  .hero-arrow {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    z-index: 2;
    display: flex;
    align-items: center;
    justify-content: center;
    width: 48px;
    height: 48px;
    border-radius: 50%;
    border: none;
    background: rgba(60, 56, 47, 0.4);
    color: var(--color-page);
    cursor: pointer;
    backdrop-filter: blur(4px);
    transition: background 0.2s ease, transform 0.2s ease;
  }

  .hero-arrow:hover {
    background: rgba(60, 56, 47, 0.65);
  }

  .hero-arrow--prev {
    left: 1.5rem;
  }

  .hero-arrow--next {
    right: 1.5rem;
  }

  /* === Content (centered) === */
  .hero-content {
    position: relative;
    z-index: 1;
    padding: 4rem 1.5rem;
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
    width: 100%;
    max-width: 900px;
  }

  .hero-headline {
    color: var(--color-page);
    font-size: clamp(3rem, 7vw, 5rem);
    line-height: 1.05;
    letter-spacing: -0.02em;
    margin-bottom: 1.25rem;
    text-wrap: balance;
  }

  .hero-subheadline {
    color: var(--color-page);
    font-size: clamp(1.05rem, 2.2vw, 1.35rem);
    line-height: 1.5;
    opacity: 0.9;
    margin-bottom: 2rem;
    max-width: 50ch;
  }

  .hero-actions {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 1rem;
  }

  /* === Scroll indicator === */
  .hero-scroll-indicator {
    position: absolute;
    bottom: 2rem;
    left: 50%;
    transform: translateX(-50%);
    z-index: 2;
    color: rgba(248, 243, 224, 0.6);
    transition: opacity 0.3s ease;
  }

  .hero-scroll-dot {
    animation: hero-scroll-bounce 2s ease-in-out infinite;
  }

  @keyframes hero-scroll-bounce {
    0%, 100% { cy: 8; opacity: 1; }
    50% { cy: 22; opacity: 0.3; }
  }

  @media (max-width: 600px) {
    .hero {
      min-height: 75vh;
    }

    .hero-scroll-indicator {
      bottom: 1.25rem;
    }

    .hero-arrow {
      width: 40px;
      height: 40px;
    }

    .hero-arrow--prev {
      left: 0.75rem;
    }

    .hero-arrow--next {
      right: 0.75rem;
    }

    .hero-arrow svg {
      width: 22px;
      height: 22px;
    }

    .hero-actions {
      flex-direction: column;
      align-items: center;
    }
  }
</style>

<script>
  document.querySelectorAll<HTMLElement>('[data-hero-slideshow]').forEach((hero) => {
    const slides = hero.querySelectorAll<HTMLImageElement>('.hero-slide');
    if (slides.length <= 1) return;

    const interval = parseInt(hero.dataset.interval || '5000', 10);
    let current = 0;
    let timer: ReturnType<typeof setInterval>;

    function goTo(index: number) {
      slides[current].classList.remove('is-active');
      current = (index + slides.length) % slides.length;
      slides[current].classList.add('is-active');
    }

    function resetTimer() {
      clearInterval(timer);
      timer = setInterval(() => goTo(current + 1), interval);
    }

    // Auto-advance
    timer = setInterval(() => goTo(current + 1), interval);

    // Arrow buttons
    const prev = hero.querySelector('[data-hero-prev]');
    const next = hero.querySelector('[data-hero-next]');

    prev?.addEventListener('click', () => {
      goTo(current - 1);
      resetTimer();
    });

    next?.addEventListener('click', () => {
      goTo(current + 1);
      resetTimer();
    });

    // Subtle parallax on scroll
    const prefersReduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    if (!prefersReduced) {
      let ticking = false;
      const heroBg = hero.querySelector<HTMLElement>('.hero-bg');

      window.addEventListener('scroll', () => {
        if (!ticking) {
          requestAnimationFrame(() => {
            const scrollY = window.scrollY;
            const heroH = hero.offsetHeight;
            if (scrollY <= heroH && heroBg) {
              const offset = scrollY * 0.25;
              heroBg.style.transform = `translate3d(0, ${offset}px, 0)`;
            }
            ticking = false;
          });
          ticking = true;
        }
      }, { passive: true });
    }
  });
</script>
