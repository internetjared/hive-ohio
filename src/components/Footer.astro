---
const currentYear = new Date().getFullYear();

const navLinks = [
  { href: '#services', label: 'Services' },
  { href: '#featured-projects', label: 'Projects' },
  { href: '#about-teaser', label: 'About' },
  { href: '#testimonials', label: 'Testimonials' },
  { href: '#contact', label: 'Contact' },
];
---

<footer class="site-footer">
  <div class="footer-inner container">
    <div class="footer-brand">
      <a href="/" aria-label="HIVE — Home">
        <img src="/images/logo/hive-lockup-earth.png" alt="HIVE — Home Improvement + Value Estimates" width="200" height="200" class="footer-logo" />
      </a>
      <p class="footer-tagline">We aim to satisfy your current needs while planning for your future.</p>
      <div class="footer-credentials">
        <p>Licensed Professional Engineer (PE) &mdash; Ohio</p>
        <p>Licensed Realtor &mdash; Ohio (SAL.2025003244)</p>
        <p>Broker: REC.2002012687</p>
      </div>
    </div>

    <div class="footer-nav">
      <h4 class="footer-heading">Navigate</h4>
      <ul>
        {navLinks.map((link) => (
          <li><a href={link.href}>{link.label}</a></li>
        ))}
      </ul>
    </div>

    <div class="footer-contact">
      <h4 class="footer-heading">Get in Touch</h4>
      <ul>
        <li><a href="mailto:hello@HIVEohio.com">hello@HIVEohio.com</a></li>
        <li>Central Ohio</li>
      </ul>
      <a href="#contact" class="btn btn-secondary footer-cta">Schedule a Consultation<span class="material-symbols-rounded" aria-hidden="true">calendar_today</span></a>
    </div>
  </div>

  <div class="footer-compliance">
    <div class="container">
      <div class="compliance-badges">
        <img src="/images/icons/nar-realtor.png" alt="REALTOR®" width="48" height="52" class="compliance-badge compliance-badge--nar" />
        <img src="/images/icons/equal-housing.png" alt="Equal Housing Opportunity" width="44" height="44" class="compliance-badge compliance-badge--eho" />
        <img src="/images/icons/keller-williams.svg" alt="Keller Williams Realty" width="80" height="36" class="compliance-badge compliance-badge--kw" />
      </div>
    </div>
  </div>

  <div class="footer-bottom">
    <div class="container">
      <p>&copy; {currentYear} HIVE &mdash; Home Improvement + Value Estimates in Ohio. All rights reserved.</p>
    </div>
  </div>
</footer>

<style>
  .site-footer {
    background-color: var(--color-earth);
    color: var(--color-page);
    padding-top: 4rem;
  }

  .footer-inner {
    display: grid;
    grid-template-columns: 1.5fr 1fr 1fr;
    gap: 3rem;
    padding-bottom: 3rem;
  }

  .footer-logo {
    width: 180px;
    height: auto;
    object-fit: contain;
    margin-bottom: 1.25rem;
    filter: brightness(0) invert(1);
    opacity: 0.9;
  }

  .footer-tagline {
    font-size: 0.95rem;
    line-height: 1.5;
    opacity: 0.85;
    margin-bottom: 1.25rem;
    max-width: 32ch;
  }

  .footer-credentials p {
    font-size: 0.8rem;
    opacity: 0.65;
    line-height: 1.6;
  }

  .footer-heading {
    font-family: var(--font-heading);
    font-size: 1rem;
    font-weight: 400;
    margin-bottom: 1.25rem;
    color: var(--color-page);
  }

  .footer-nav ul,
  .footer-contact ul {
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
  }

  .footer-nav a,
  .footer-contact a,
  .footer-contact li {
    font-size: 0.875rem;
    opacity: 0.75;
    transition: opacity var(--transition-fast);
  }

  .footer-nav a:hover,
  .footer-contact a:hover {
    opacity: 1;
  }

  .footer-cta {
    margin-top: 1.5rem;
    font-size: 0.75rem;
    padding: 0.6rem 1.25rem;
  }

  .footer-compliance {
    border-top: 1px solid rgba(248, 243, 224, 0.1);
    padding: 1.25rem 0;
  }

  .compliance-badges {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 2rem;
  }

  .compliance-badge {
    height: auto;
    opacity: 0.7;
  }

  .compliance-badge--nar {
    width: 48px;
  }

  .compliance-badge--eho {
    width: 44px;
    filter: invert(1);
  }

  .compliance-badge--kw {
    width: 80px;
    filter: brightness(3);
  }

  .footer-bottom {
    border-top: 1px solid rgba(248, 243, 224, 0.06);
    padding: 1.5rem 0;
  }

  .footer-bottom p {
    font-size: 0.75rem;
    opacity: 0.5;
    text-align: center;
  }

  @media (max-width: 768px) {
    .footer-inner {
      grid-template-columns: 1fr;
      gap: 2.5rem;
    }
  }
</style>
