---
interface Props {
  heading?: string;
  subtext?: string;
  formAccessKey?: string;
}

const {
  heading = "Let's Talk About Your Home",
  subtext = "Free consultations. No pressure. Tell us a little about what you're looking for.",
  formAccessKey = "",
} = Astro.props;
---

<div class="contact-form-wrap" data-contact-form>
  <div class="contact-form-header">
    <h2>{heading}</h2>
    {subtext && <p class="contact-form-sub">{subtext}</p>}
  </div>

  <form class="contact-form" data-form-key={formAccessKey}>
    <input type="hidden" name="access_key" value={formAccessKey} />
    <input type="hidden" name="subject" value="New HIVE Contact Form Submission" />
    <input type="hidden" name="from_name" value="HIVE Ohio Website" />
    <input type="checkbox" name="botcheck" class="hidden-check" style="display:none" />

    <div class="form-row form-row--half">
      <div class="form-group">
        <label for="contact-name">Name</label>
        <input type="text" id="contact-name" name="name" required autocomplete="name" placeholder="Your name" />
      </div>
      <div class="form-group">
        <label for="contact-email">Email</label>
        <input type="email" id="contact-email" name="email" required autocomplete="email" placeholder="you@example.com" />
      </div>
    </div>

    <div class="form-row form-row--half">
      <div class="form-group">
        <label for="contact-phone">Phone <span class="optional">(optional)</span></label>
        <input type="tel" id="contact-phone" name="phone" autocomplete="tel" placeholder="(555) 123-4567" />
      </div>
      <div class="form-group">
        <label for="contact-interest">I'm interested in</label>
        <select id="contact-interest" name="interest" required>
          <option value="" disabled selected>Select one...</option>
          <option value="Real Estate">Real Estate</option>
          <option value="Renovation">Renovation</option>
          <option value="DIY Coaching">DIY Coaching</option>
          <option value="General Inquiry">Just Exploring</option>
        </select>
      </div>
    </div>

    <div class="form-group">
      <label for="contact-message">Tell us more <span class="optional">(optional)</span></label>
      <textarea id="contact-message" name="message" rows="4" placeholder="What are you working on? What questions do you have?"></textarea>
    </div>

    <button type="submit" class="btn btn-primary form-submit">
      <span class="submit-text">Send Message</span>
      <span class="submit-loading" aria-hidden="true">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none">
          <circle cx="12" cy="12" r="10" stroke="currentColor" stroke-width="2.5" stroke-dasharray="31.4 31.4" stroke-linecap="round">
            <animateTransform attributeName="transform" type="rotate" dur="0.8s" from="0 12 12" to="360 12 12" repeatCount="indefinite"/>
          </circle>
        </svg>
      </span>
    </button>
  </form>

  <div class="form-success" aria-live="polite">
    <div class="success-icon">
      <svg width="48" height="48" viewBox="0 0 48 48" fill="none">
        <circle cx="24" cy="24" r="22" stroke="currentColor" stroke-width="2"/>
        <path d="M15 24L22 31L34 17" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/>
      </svg>
    </div>
    <h3>Message Sent</h3>
    <p>Thanks for reaching out! We'll get back to you within 24 hours.</p>
  </div>
</div>

<style>
  .contact-form-wrap {
    max-width: 680px;
    margin-inline: auto;
  }

  .contact-form-header {
    text-align: center;
    margin-bottom: 2.5rem;
  }

  .contact-form-sub {
    margin-top: 0.75rem;
    margin-inline: auto;
    font-size: 1.05rem;
    opacity: 0.7;
  }

  /* Form layout */
  .contact-form {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }

  .form-row--half {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1.25rem;
  }

  .form-group {
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
  }

  label {
    font-size: 0.85rem;
    font-weight: 700;
    letter-spacing: 0.03em;
    text-transform: uppercase;
    color: var(--color-earth);
  }

  .optional {
    font-weight: 400;
    text-transform: none;
    letter-spacing: 0;
    opacity: 0.5;
  }

  input,
  select,
  textarea {
    width: 100%;
    padding: 0.8rem 1rem;
    font-family: var(--font-body);
    font-size: 0.95rem;
    color: var(--color-earth);
    background: rgba(121, 137, 88, 0.06);
    border: 1.5px solid rgba(121, 137, 88, 0.18);
    border-radius: 8px;
    transition: border-color 0.2s ease, box-shadow 0.2s ease, background-color 0.2s ease;
  }

  input::placeholder,
  textarea::placeholder {
    color: var(--color-earth);
    opacity: 0.35;
  }

  select {
    cursor: pointer;
    appearance: none;
    background-image: url("data:image/svg+xml,%3Csvg width='12' height='8' viewBox='0 0 12 8' fill='none' xmlns='http://www.w3.org/2000/svg'%3E%3Cpath d='M1 1.5L6 6.5L11 1.5' stroke='%233c382f' stroke-width='1.5' stroke-linecap='round' stroke-linejoin='round'/%3E%3C/svg%3E");
    background-repeat: no-repeat;
    background-position: right 1rem center;
    padding-right: 2.5rem;
  }

  /* Focus states */
  input:focus,
  select:focus,
  textarea:focus {
    outline: none;
    border-color: var(--color-olive);
    box-shadow: 0 0 0 3px rgba(121, 137, 88, 0.15);
    background: rgba(121, 137, 88, 0.03);
  }

  textarea {
    resize: vertical;
    min-height: 100px;
  }

  /* Submit button */
  .form-submit {
    align-self: stretch;
    margin-top: 0.5rem;
    width: 100%;
  }

  .submit-loading {
    display: none;
  }

  .contact-form.is-loading .submit-text {
    display: none;
  }

  .contact-form.is-loading .submit-loading {
    display: flex;
  }

  .contact-form.is-loading .form-submit {
    pointer-events: none;
    opacity: 0.7;
  }

  /* Success state */
  .form-success {
    display: none;
    text-align: center;
    padding: 3rem 1rem;
  }

  .form-success.is-visible {
    display: block;
    animation: successFadeIn 0.5s ease;
  }

  .success-icon {
    color: var(--color-olive);
    margin-bottom: 1.25rem;
  }

  .form-success h3 {
    margin-bottom: 0.5rem;
  }

  .form-success p {
    margin-inline: auto;
    opacity: 0.7;
  }

  .contact-form.is-hidden {
    display: none;
  }

  @keyframes successFadeIn {
    from { opacity: 0; transform: translateY(12px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  /* Error state */
  .form-group.has-error input,
  .form-group.has-error select,
  .form-group.has-error textarea {
    border-color: var(--color-terracotta-red);
    box-shadow: 0 0 0 3px rgba(165, 82, 28, 0.12);
  }

  /* Mobile */
  @media (max-width: 600px) {
    .form-row--half {
      grid-template-columns: 1fr;
    }

    .form-submit {
      width: 100%;
    }

    .contact-form-header {
      text-align: left;
    }
  }
</style>

<script>
  document.querySelectorAll<HTMLElement>('[data-contact-form]').forEach((wrap) => {
    const form = wrap.querySelector<HTMLFormElement>('.contact-form');
    const success = wrap.querySelector<HTMLElement>('.form-success');
    if (!form || !success) return;

    const accessKey = form.dataset.formKey || '';

    form.addEventListener('submit', async (e) => {
      e.preventDefault();

      // Clear previous errors
      form.querySelectorAll('.has-error').forEach(g => g.classList.remove('has-error'));

      // Validate
      const name = (form.querySelector<HTMLInputElement>('#contact-name')!).value.trim();
      const email = (form.querySelector<HTMLInputElement>('#contact-email')!).value.trim();
      const phone = (form.querySelector<HTMLInputElement>('#contact-phone')!).value.trim();
      const interest = (form.querySelector<HTMLSelectElement>('#contact-interest')!).value;
      const message = (form.querySelector<HTMLTextAreaElement>('#contact-message')!).value.trim();

      let valid = true;
      if (!name) { form.querySelector('#contact-name')?.closest('.form-group')?.classList.add('has-error'); valid = false; }
      if (!email) { form.querySelector('#contact-email')?.closest('.form-group')?.classList.add('has-error'); valid = false; }
      if (!interest) { form.querySelector('#contact-interest')?.closest('.form-group')?.classList.add('has-error'); valid = false; }

      if (!valid) return;

      form.classList.add('is-loading');

      try {
        if (accessKey) {
          const res = await fetch('https://api.web3forms.com/submit', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json', 'Accept': 'application/json' },
            body: JSON.stringify({
              access_key: accessKey,
              name,
              email,
              phone,
              interest,
              message,
              subject: 'New HIVE Contact Form Submission',
              from_name: 'HIVE Ohio Website',
            }),
          });

          const data = await res.json();
          if (!data.success) {
            console.error('Web3Forms error:', data);
          }
        }

        // Log to Google Sheet (fire and forget — don't block success)
        fetch('https://script.google.com/macros/s/AKfycbxHRLxa3iHfEBfaAqKyJCyrNvgH992B8rvOjqfjQI6lajYVlZq25JODye7pj0d4hxJl/exec', {
          method: 'POST',
          body: JSON.stringify({ name, email, phone, interest, message }),
        }).catch(() => {});

        // Show success
        form.classList.add('is-hidden');
        form.classList.remove('is-loading');
        success.classList.add('is-visible');
      } catch (err) {
        console.error('Form submission error:', err);
        form.classList.remove('is-loading');
        // Still show success to not block user
        form.classList.add('is-hidden');
        success.classList.add('is-visible');
      }
    });
  });
</script>
