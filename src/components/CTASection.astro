---
interface Props {
  headline: string;
  subtext?: string;
  buttonText: string;
  buttonLink: string;
  secondaryText?: string;
  secondaryLink?: string;
  backgroundType?: 'color' | 'image';
  backgroundValue?: string;
}

const {
  headline,
  subtext,
  buttonText,
  buttonLink,
  secondaryText,
  secondaryLink,
  backgroundType = 'color',
  backgroundValue = 'var(--color-olive)',
} = Astro.props;

const isImage = backgroundType === 'image';
---

<section class="cta-section" class:list={{ 'cta-section--image': isImage }}>
  {isImage && (
    <div class="cta-bg">
      <img src={backgroundValue} alt="" loading="lazy" />
      <div class="cta-overlay"></div>
    </div>
  )}
  {!isImage && <div class="cta-bg-color" style={`background-color: ${backgroundValue}`}></div>}

  <div class="cta-content container">
    <h2 class="cta-headline">{headline}</h2>
    {subtext && <p class="cta-subtext">{subtext}</p>}
    <div class="cta-actions">
      <a href={buttonLink} class="btn btn-light">{buttonText}</a>
      {secondaryText && secondaryLink && (
        <a href={secondaryLink} class="cta-secondary">{secondaryText}</a>
      )}
    </div>
  </div>
</section>

<style>
  .cta-section {
    position: relative;
    padding: 10rem 0;
    text-align: center;
    overflow: hidden;
  }

  .cta-bg {
    position: absolute;
    inset: 0;
  }

  .cta-bg img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .cta-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      180deg,
      rgba(60, 56, 47, 0.6) 0%,
      rgba(60, 56, 47, 0.75) 100%
    );
  }

  .cta-bg-color {
    position: absolute;
    inset: 0;
  }

  .cta-content {
    position: relative;
    z-index: 1;
  }

  .cta-headline {
    color: var(--color-page);
    font-size: clamp(1.75rem, 4vw, 2.75rem);
    margin-bottom: 1rem;
    text-wrap: balance;
  }

  .cta-subtext {
    color: var(--color-page);
    font-size: clamp(1rem, 2vw, 1.15rem);
    opacity: 0.9;
    margin-bottom: 2rem;
    margin-inline: auto;
    max-width: 50ch;
  }

  .cta-actions {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1rem;
  }

  .cta-secondary {
    color: var(--color-page);
    font-size: 0.875rem;
    opacity: 0.75;
    text-decoration: underline;
    text-underline-offset: 3px;
    transition: opacity var(--transition-fast);
  }

  .cta-secondary:hover {
    opacity: 1;
  }
</style>
