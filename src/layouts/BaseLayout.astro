---
import BaseHead from '../components/BaseHead.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import ScrollReveal from '../components/ScrollReveal.astro';
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
  image?: string;
  currentPage?: string;
  noindex?: boolean;
}

const { title, description, image, currentPage, noindex } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <BaseHead title={title} description={description} image={image} noindex={noindex} />
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@graph": [
        {
          "@type": "LocalBusiness",
          "@id": "https://hiveohio.com/#business",
          "name": "HIVE — Home Improvement + Value Estimates in Ohio",
          "alternateName": "HIVE Ohio",
          "description": "Real estate, renovations, and homeowner guidance in Central Ohio. Licensed Professional Engineer and Realtor.",
          "url": "https://hiveohio.com",
          "logo": "https://hiveohio.com/images/logo/hive-logo-green.png",
          "image": "https://hiveohio.com/images/photos/favorites/2010mh-living-fireplace.jpg",
          "email": "hello@HIVEohio.com",
          "areaServed": {
            "@type": "GeoCircle",
            "geoMidpoint": {
              "@type": "GeoCoordinates",
              "latitude": 39.9612,
              "longitude": -82.9988
            },
            "geoRadius": "80467"
          },
          "address": {
            "@type": "PostalAddress",
            "addressRegion": "OH",
            "addressCountry": "US"
          },
          "knowsAbout": [
            "Real Estate",
            "Home Renovation",
            "Construction",
            "DIY Coaching",
            "Home Improvement",
            "Property Evaluation"
          ],
          "hasOfferCatalog": {
            "@type": "OfferCatalog",
            "name": "HIVE Services",
            "itemListElement": [
              {
                "@type": "Offer",
                "itemOffered": {
                  "@type": "Service",
                  "name": "Real Estate",
                  "description": "Real estate guidance for buyers and sellers in Central Ohio."
                }
              },
              {
                "@type": "Offer",
                "itemOffered": {
                  "@type": "Service",
                  "name": "Renovations",
                  "description": "Hands-on construction from kitchens to whole-house transformations with PE-backed planning."
                }
              },
              {
                "@type": "Offer",
                "itemOffered": {
                  "@type": "Service",
                  "name": "DIY Coaching",
                  "description": "One-on-one guidance for homeowners who want to be involved in their renovation process."
                }
              }
            ]
          }
        },
        {
          "@type": "WebSite",
          "@id": "https://hiveohio.com/#website",
          "url": "https://hiveohio.com",
          "name": "HIVE — Home Improvement + Value Estimates in Ohio",
          "publisher": { "@id": "https://hiveohio.com/#business" }
        },
        {
          "@type": "WebPage",
          "@id": "https://hiveohio.com/#webpage",
          "url": "https://hiveohio.com",
          "name": title,
          "description": description || "Real estate, renovations, and homeowner guidance in Central Ohio.",
          "isPartOf": { "@id": "https://hiveohio.com/#website" },
          "about": { "@id": "https://hiveohio.com/#business" }
        }
      ]
    })} />
  </head>
  <body>
    <Nav currentPage={currentPage} />
    <main>
      <slot />
    </main>
    <Footer />
    <ScrollReveal />
  </body>
</html>
